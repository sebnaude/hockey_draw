# .gitignore

# Ignore environment
.venv/

# Checkpoints (solver output - don't track)
checkpoints/

# Draws folder - solver output (keep .gitkeep)
draws/**
!draws/.gitkeep

# Logs - solver output
logs/

# Backup files
*.bak
~$*
nppBackup/

# Python cache
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Legacy code (kept for reference but not tracked)
_legacy/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/
*.ipynb

# Pickle files (model state)
*.pkl
*.pickle

# Temp Excel files
~$*

# Loose Excel/CSV draft outputs at repo root (formal outputs live in draws/)
/2026 Season Draw*.xlsx
/Week*.csv

# Worktree dir for parallel agent sessions
.claude/

# ======================
# INPUT DATA - TRACK THIS
# ======================
# Team CSV files in data/ are REQUIRED input - track them
# data/2025/teams/*.csv - team rosters
# data/2025/noplay/*.csv - unavailability data
# data/2025/field_availability/*.csv - field schedules
# data/2025/documentation.txt - season documentation
# Coverage artifacts (spec-034 runner)
.coverage
.coverage.*
htmlcov/
